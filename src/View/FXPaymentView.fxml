<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20.0" style="-fx-background-color: #f8f9fa;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://fxml.com/fxml/1" fx:controller="Controller.FXPaymentController">
    <padding>
        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
    </padding>
    
    <Label text="Payment Logging Dashboard" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #212529;" />

    <GridPane hgap="15.0" vgap="12.0">
        <columnConstraints>
            <ColumnConstraints minWidth="100.0" prefWidth="110.0" />
            <ColumnConstraints hgrow="ALWAYS" />
            <ColumnConstraints minWidth="100.0" prefWidth="110.0" />
            <ColumnConstraints hgrow="ALWAYS" />
            <ColumnConstraints minWidth="100.0" prefWidth="110.0" />
            <ColumnConstraints hgrow="ALWAYS" />
        </columnConstraints>
        
        <children>
            <Label fx:id="lblPaymentId" text="Payment ID:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <TextField fx:id="txtPaymentId" promptText="Payment ID" style="-fx-background-radius: 4; -fx-border-radius: 4; -fx-border-color: #ced4da;" GridPane.columnIndex="1" GridPane.rowIndex="0" />
            
            <Label text="Select Booking:" GridPane.columnIndex="2" GridPane.rowIndex="0" />
            <ComboBox fx:id="cmbBooking" promptText="Select Booking" maxWidth="Infinity" GridPane.columnIndex="3" GridPane.rowIndex="0" />
            
            <Label text="Amount (Auto):" GridPane.columnIndex="4" GridPane.rowIndex="0" />
            <TextField fx:id="txtAmount" editable="false" promptText="Auto" style="-fx-background-color: #e9ecef; -fx-border-color: #ced4da;" GridPane.columnIndex="5" GridPane.rowIndex="0" />
            
            <Label text="Payment Method:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
            <TextField fx:id="txtPaymentMethod" promptText="e.g. Cash, Card" style="-fx-background-radius: 4; -fx-border-radius: 4; -fx-border-color: #ced4da;" GridPane.columnIndex="1" GridPane.rowIndex="1" />
            
            <Label text="Transaction Ref:" GridPane.columnIndex="2" GridPane.rowIndex="1" />
            <TextField fx:id="txtTransactionRef" promptText="Ref Number" style="-fx-background-radius: 4; -fx-border-radius: 4; -fx-border-color: #ced4da;" GridPane.columnIndex="3" GridPane.rowIndex="1" />
            
            <Label text="Status (Auto):" GridPane.columnIndex="4" GridPane.rowIndex="1" />
            <TextField fx:id="txtPaymentStatus" editable="false" promptText="Auto" style="-fx-background-color: #e9ecef; -fx-border-color: #ced4da;" GridPane.columnIndex="5" GridPane.rowIndex="1" />
        </children>
    </GridPane>

    <HBox spacing="12.0" alignment="CENTER_LEFT">
        <children>
            <Button fx:id="btnAdd" text="Record Payment" onAction="#addPayment" style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 16; -fx-background-radius: 4;" />
            <Button fx:id="btnUpdate" text="Update Record" onAction="#updatePayment" style="-fx-background-color: #007bff; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 16; -fx-background-radius: 4;" />
            <Button fx:id="btnDelete" text="Delete Entry" onAction="#deletePayment" style="-fx-background-color: #dc3545; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 16; -fx-background-radius: 4;" />
            <Button fx:id="btnSearch" text="Search Code" onAction="#searchPayment" style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 16; -fx-background-radius: 4;" />
        </children>
    </HBox>

    <TableView fx:id="table" VBox.vgrow="ALWAYS" style="-fx-background-radius: 4;">
        <columns>
            <TableColumn fx:id="colId" text="Payment ID" prefWidth="90.0" />
            <TableColumn fx:id="colBookingId" text="Booking ID" prefWidth="90.0" />
            <TableColumn fx:id="colAmount" text="Amount" prefWidth="100.0" />
            <TableColumn fx:id="colMethod" text="Method" prefWidth="110.0" />
            <TableColumn fx:id="colRef" text="Transaction Reference" prefWidth="180.0" />
            <TableColumn fx:id="colStatus" text="Status" prefWidth="100.0" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>
</VBox>