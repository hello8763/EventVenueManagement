<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20.0" style="-fx-background-color: #f8f9fa;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://fxml.com/fxml/1" fx:controller="Controller.FXEventTypeController">
    <padding>
        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
    </padding>
    
    <Label text="Event Type Configuration" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #212529;" />

    <GridPane hgap="15.0" vgap="12.0">
        <columnConstraints>
            <ColumnConstraints minWidth="100.0" prefWidth="110.0" />
            <ColumnConstraints hgrow="ALWAYS" />
            <ColumnConstraints minWidth="100.0" prefWidth="110.0" />
            <ColumnConstraints hgrow="ALWAYS" />
        </columnConstraints>
        
        <children>
            <Label text="Type ID (Search/Edit):" GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <TextField fx:id="txtId" promptText="Enter ID" style="-fx-background-radius: 4; -fx-border-radius: 4; -fx-border-color: #ced4da;" GridPane.columnIndex="1" GridPane.rowIndex="0" />
            
            <Label text="Event Name:" GridPane.columnIndex="2" GridPane.rowIndex="0" />
            <TextField fx:id="txtName" promptText="e.g. Wedding, Seminar" style="-fx-background-radius: 4; -fx-border-radius: 4; -fx-border-color: #ced4da;" GridPane.columnIndex="3" GridPane.rowIndex="0" />
            
            <Label text="Description:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
            <TextField fx:id="txtDesc" promptText="Type details" style="-fx-background-radius: 4; -fx-border-radius: 4; -fx-border-color: #ced4da;" GridPane.columnIndex="1" GridPane.rowIndex="1" />
            
            <Label text="Required Deposit:" GridPane.columnIndex="2" GridPane.rowIndex="1" />
            <TextField fx:id="txtDeposit" promptText="0.00" style="-fx-background-radius: 4; -fx-border-radius: 4; -fx-border-color: #ced4da;" GridPane.columnIndex="3" GridPane.rowIndex="1" />
        </children>
    </GridPane>

    <HBox spacing="12.0" alignment="CENTER_LEFT">
        <children>
            <Button fx:id="btnAdd" text="Add Type" onAction="#add" style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 16; -fx-background-radius: 4;" />
            <Button fx:id="btnUpdate" text="Update Changes" onAction="#update" style="-fx-background-color: #007bff; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 16; -fx-background-radius: 4;" />
            <Button fx:id="btnDelete" text="Delete Entry" onAction="#delete" style="-fx-background-color: #dc3545; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 16; -fx-background-radius: 4;" />
            <Button fx:id="btnSearch" text="Search Index" onAction="#search" style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 16; -fx-background-radius: 4;" />
        </children>
    </HBox>

    <TableView fx:id="table" VBox.vgrow="ALWAYS" style="-fx-background-radius: 4;">
        <columns>
            <TableColumn fx:id="colId" text="Type ID" prefWidth="80.0" />
            <TableColumn fx:id="colName" text="Name" prefWidth="150.0" />
            <TableColumn fx:id="colDesc" text="Description" prefWidth="280.0" />
            <TableColumn fx:id="colDeposit" text="Base Deposit" prefWidth="120.0" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>
</VBox>