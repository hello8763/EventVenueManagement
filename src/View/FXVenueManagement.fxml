<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<HBox prefWidth="950" prefHeight="600" spacing="20" styleClass="main-container" stylesheets="@style.css" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.FXVenueController">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <VBox prefWidth="320" spacing="15" styleClass="form-panel">
        <Label text="Venue Controls" styleClass="header-label"/>
        <Separator/>
        
        <VBox spacing="5">
            <Label text="Venue ID (For Search/Update/Delete)"/>
            <HBox spacing="10">
                <TextField fx:id="txtVenueId" promptText="ID" HBox.hgrow="ALWAYS"/>
                <Button text="Search" onAction="#handleSearch" styleClass="secondary-button"/>
            </HBox>
        </VBox>

        <VBox spacing="5">
            <Label text="Venue Name"/>
            <TextField fx:id="txtName" promptText="E.g., Grand Ballroom"/>
        </VBox>

        <VBox spacing="5">
            <Label text="Location"/>
            <TextField fx:id="txtLocation" promptText="E.g., Hall A, 2nd Floor"/>
        </VBox>

        <VBox spacing="5">
            <Label text="Capacity"/>
            <TextField fx:id="txtCapacity" promptText="E.g., 500"/>
        </VBox>

        <VBox spacing="5">
            <Label text="Hourly Rate ($)"/>
            <TextField fx:id="txtHourlyRate" promptText="E.g., 150.00"/>
        </VBox>

        <VBox spacing="5">
            <Label text="Status"/>
            <TextField fx:id="txtStatus" promptText="E.g., Available / Maintenance"/>
        </VBox>

        <Region VBox.vgrow="ALWAYS"/>

        <GridPane hgap="10" vgap="10">
            <columnConstraints>
                <ColumnConstraints percentWidth="50"/>
                <ColumnConstraints percentWidth="50"/>
            </columnConstraints>
            <rowConstraints>
                <RowConstraints/>
            </rowConstraints>
            <Button text="Add New" onAction="#handleAdd" maxWidth="Infinity" styleClass="primary-button" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <Button text="Update" onAction="#handleUpdate" maxWidth="Infinity" styleClass="action-button-blue" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
            <Button text="Delete" onAction="#handleDelete" maxWidth="Infinity" styleClass="action-button-red" GridPane.rowIndex="1" GridPane.columnIndex="0" GridPane.columnSpan="2"/>
        </GridPane>
    </VBox>

    <VBox HBox.hgrow="ALWAYS" spacing="10">
        <Label text="Registered Venues Log" styleClass="section-title"/>
        <TableView fx:id="tblVenues" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
                <TableColumn fx:id="colName" text="Name" prefWidth="180"/>
                <TableColumn fx:id="colLocation" text="Location" prefWidth="150"/>
                <TableColumn fx:id="colCapacity" text="Capacity" prefWidth="90"/>
                <TableColumn fx:id="colHourlyRate" text="Hourly Rate" prefWidth="100"/>
                <TableColumn fx:id="colStatus" text="Status" prefWidth="100"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
        </TableView>
    </VBox>
</HBox>