<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20.0" style="-fx-background-color: #f8f9fa;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://fxml.com/fxml/1" fx:controller="Controller.FXBookingController">
    <padding>
        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
    </padding>
    
    <Label text="Booking Management" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #212529;" />

    <GridPane hgap="15.0" vgap="12.0">
        <columnConstraints>
            <ColumnConstraints minWidth="90.0" prefWidth="100.0" />
            <ColumnConstraints hgrow="ALWAYS" />
            <ColumnConstraints minWidth="90.0" prefWidth="100.0" />
            <ColumnConstraints hgrow="ALWAYS" />
            <ColumnConstraints minWidth="90.0" prefWidth="100.0" />
            <ColumnConstraints hgrow="ALWAYS" />
        </columnConstraints>
        
        <children>
            <Label text="Booking ID:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <TextField fx:id="txtBookingId" promptText="Booking ID" style="-fx-background-radius: 4; -fx-border-radius: 4; -fx-border-color: #ced4da;" GridPane.columnIndex="1" GridPane.rowIndex="0" />
            
            <Label text="User ID:" GridPane.columnIndex="2" GridPane.rowIndex="0" />
            <TextField fx:id="txtUserId" promptText="User ID" style="-fx-background-radius: 4; -fx-border-radius: 4; -fx-border-color: #ced4da;" GridPane.columnIndex="3" GridPane.rowIndex="0" />
            
            <Label text="Venue ID:" GridPane.columnIndex="4" GridPane.rowIndex="0" />
            <TextField fx:id="txtVenueId" promptText="Venue ID" style="-fx-background-radius: 4; -fx-border-radius: 4; -fx-border-color: #ced4da;" GridPane.columnIndex="5" GridPane.rowIndex="0" />
            
            <Label text="Type ID:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
            <TextField fx:id="txtTypeId" promptText="Type ID" style="-fx-background-radius: 4; -fx-border-radius: 4; -fx-border-color: #ced4da;" GridPane.columnIndex="1" GridPane.rowIndex="1" />
            
            <Label text="Event Date:" GridPane.columnIndex="2" GridPane.rowIndex="1" />
            <TextField fx:id="txtEventDate" promptText="YYYY-MM-DD" style="-fx-background-radius: 4; -fx-border-radius: 4; -fx-border-color: #ced4da;" GridPane.columnIndex="3" GridPane.rowIndex="1" />
            
            <Label text="Start Time:" GridPane.columnIndex="4" GridPane.rowIndex="1" />
            <TextField fx:id="txtStartTime" promptText="HH:MM" style="-fx-background-radius: 4; -fx-border-radius: 4; -fx-border-color: #ced4da;" GridPane.columnIndex="5" GridPane.rowIndex="1" />
            
            <Label text="End Time:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
            <TextField fx:id="txtEndTime" promptText="HH:MM" style="-fx-background-radius: 4; -fx-border-radius: 4; -fx-border-color: #ced4da;" GridPane.columnIndex="1" GridPane.rowIndex="2" />
            
            <Label text="Total Price:" GridPane.columnIndex="2" GridPane.rowIndex="2" />
            <TextField fx:id="txtTotalPrice" promptText="Total Price" style="-fx-background-radius: 4; -fx-border-radius: 4; -fx-border-color: #ced4da;" GridPane.columnIndex="3" GridPane.rowIndex="2" />
            
            <Label text="Status:" GridPane.columnIndex="4" GridPane.rowIndex="2" />
            <TextField fx:id="txtStatus" promptText="Status" style="-fx-background-radius: 4; -fx-border-radius: 4; -fx-border-color: #ced4da;" GridPane.columnIndex="5" GridPane.rowIndex="2" />
        </children>
    </GridPane>

    <HBox spacing="12.0" alignment="CENTER_LEFT">
        <children>
            <Button fx:id="btnAdd" text="Add Booking" onAction="#addBooking" style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 16; -fx-background-radius: 4;" />
            <Button fx:id="btnUpdate" text="Update" onAction="#updateBooking" style="-fx-background-color: #007bff; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 16; -fx-background-radius: 4;" />
            <Button fx:id="btnDelete" text="Delete" onAction="#deleteBooking" style="-fx-background-color: #dc3545; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 16; -fx-background-radius: 4;" />
            <Button fx:id="btnSearch" text="Search" onAction="#searchBooking" style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 16; -fx-background-radius: 4;" />
        </children>
    </HBox>

    <TableView fx:id="table" VBox.vgrow="ALWAYS" style="-fx-background-radius: 4;">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="50.0" />
            <TableColumn fx:id="colUser" text="User ID" prefWidth="80.0" />
            <TableColumn fx:id="colVenue" text="Venue ID" prefWidth="80.0" />
            <TableColumn fx:id="colType" text="Type ID" prefWidth="80.0" />
            <TableColumn fx:id="colDate" text="Date" prefWidth="100.0" />
            <TableColumn fx:id="colStart" text="Start Time" prefWidth="90.0" />
            <TableColumn fx:id="colEnd" text="End Time" prefWidth="90.0" />
            <TableColumn fx:id="colPrice" text="Total Price" prefWidth="100.0" />
            <TableColumn fx:id="colStatus" text="Status" prefWidth="90.0" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>
</VBox>