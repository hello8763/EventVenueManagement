<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15.0" style="-fx-background-color: #f8f9fa;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://fxml.com/fxml/1" fx:controller="Controller.FXUserListController">
    <padding>
        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
    </padding>
    
    <HBox alignment="CENTER_LEFT" spacing="15.0">
        <children>
            <VBox HBox.hgrow="ALWAYS">
                <children>
                    <Label text="System Users Database" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #212529;" />
                    <Label text="Read-only administrative ledger profile registry" style="-fx-font-size: 12px; -fx-text-fill: #6c757d;" />
                </children>
            </VBox>
            <Button text="Refresh Table Layout" onAction="#loadUsers" style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 16; -fx-background-radius: 4;" />
        </children>
    </HBox>

    <TableView fx:id="table" VBox.vgrow="ALWAYS" style="-fx-background-radius: 4;">
        <columns>
            <TableColumn fx:id="colUserId" text="User ID" prefWidth="80.0" />
            <TableColumn fx:id="colFullName" text="Full Name" prefWidth="150.0" />
            <TableColumn fx:id="colEmail" text="Email Address" prefWidth="180.0" />
            <TableColumn fx:id="colPhone" text="Phone Contact" prefWidth="120.0" />
            <TableColumn fx:id="colRole" text="Access Authority Role" prefWidth="110.0" />
            <TableColumn fx:id="colAddress" text="Physical Registered Address" prefWidth="180.0" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>
</VBox>